#include <iostream>
using namespace std;

int main() {
    int arr[] = {1, 2, 4, 5};
    int n = 5; // total numbers should be 1 to 5

    int totalSum = n * (n + 1) / 2;
    int arrSum = 0;

    for (int i = 0; i < n - 1; i++) {
        arrSum += arr[i];
    }

    int missing = totalSum - arrSum;

    cout << "Missing = " << missing << endl;

    return 0;
}
