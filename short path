#include <stdio.h>

#define INF 99999

int main() {
    int n, i, j, k;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    int A[n][n];

    printf("Enter weighted adjacency matrix (use 99999 for INF):\n");

    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    // Floyd Warshall Algorithm
    for(k = 0; k < n; k++) {
        for(i = 0; i < n; i++) {
            for(j = 0; j < n; j++) {

                if (A[i][k] + A[k][j] < A[i][j]) {
                    A[i][j] = A[i][k] + A[k][j];
                }

            }
        }
    }

    printf("\nShortest Path Matrix:\n");

    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {

            if(A[i][j] == INF)
                printf("INF ");
            else
                printf("%d ", A[i][j]);

        }
        printf("\n");
    }

    return 0;
}
