#include <stdio.h>

int main() {
    int n, i, j, k;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    int A[n][n];

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    // Warshall Algorithm
    for(k = 0; k < n; k++) {
        for(i = 0; i < n; i++) {
            for(j = 0; j < n; j++) {
                A[i][j] = A[i][j] || (A[i][k] && A[k][j]);
            }
        }
    }

    printf("\nPath Matrix is:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            printf("%d ", A[i][j]);
        }
        printf("\n");
    }

    return 0;
}
