#include <iostream>
using namespace std;

int main() {
    int a, b;
    cin >> a >> b;

    // Normal method
    int gcd1 = 1;
    for (int i = 1; i <= min(a, b); i++) {
        if (a % i == 0 && b % i == 0) {
            gcd1 = i;
        }
    }

    // Euclidean method
    int x = a, y = b;
    while (y != 0) {
        int temp = y;
        y = x % y;
        x = temp;
    }

    cout << "GCD (Normal) = " << gcd1 << endl;
    cout << "GCD (Euclidean) = " << x << endl;

    return 0;
}
