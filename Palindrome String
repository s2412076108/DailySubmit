#include <iostream>
using namespace std;

int main() {
    string str;
    cin >> str;

    bool isPalindrome = true;
    int n = str.length();

    for (int i = 0; i < n / 2; i++) {
        if (str[i] != str[n - i - 1]) {
            isPalindrome = false;
            break;
        }
    }

    if (isPalindrome)
        cout << "Yes" << endl;
    else
        cout << "No" << endl;

    return 0;
}
