#include <iostream>
using namespace std;

int main() {
    int n, sum = 0, rev = 0;
    cin >> n;

    int temp = n;

    while (temp > 0) {
        int digit = temp % 10;
        sum += digit;
        rev = rev * 10 + digit;
        temp /= 10;
    }

    cout << "Sum = " << sum << endl;
    cout << "Reverse = " << rev << endl;

    return 0;
}
